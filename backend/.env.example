# ---- Pamodzi Finance backend configuration ----

DATABASE_URL=postgres://postgres:postgres@localhost:5432/pamodzi
SERVER_ADDR=0.0.0.0:8080

# REQUIRED — generate with: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRY_HOURS=72

# REQUIRED — generate with: openssl rand -hex 32
ENCRYPTION_KEY=

FRONTEND_ORIGIN=http://localhost:3001

# Production: comma-separated allowed origins (Vercel + local dev)
# FRONTEND_ORIGIN=https://your-app.vercel.app,http://localhost:3001

# ---- Stellar (TESTNET ONLY) ----
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_FRIENDBOT_URL=https://friendbot.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

RUST_LOG=info,pamodzi_backend=debug,tower_http=info
