# ---- Pamodzi Finance backend configuration ----

# PostgreSQL connection string
DATABASE_URL=postgres://postgres:postgres@localhost:5432/pamodzi

# Host:port the Axum server binds to
SERVER_ADDR=0.0.0.0:8080

# Secret used to sign JWTs (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret
# Token lifetime in hours
JWT_EXPIRY_HOURS=72

# CORS: allowed frontend origin
FRONTEND_ORIGIN=http://localhost:3000

# ---- Stellar (TESTNET ONLY) ----
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_FRIENDBOT_URL=https://friendbot.stellar.org
STELLAR_NETWORK=testnet

# Email of the bootstrap platform admin. On first boot, if this user
# registers (or already exists) they are granted the platform_admin role.
PLATFORM_ADMIN_EMAIL=admin@pamodzi.africa

RUST_LOG=info,pamodzi_backend=debug,tower_http=info
